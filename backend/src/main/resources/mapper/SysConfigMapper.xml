<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.community.platform.generated.mapper.SysConfigMapper">

    <resultMap id="BaseResultMap" type="com.community.platform.generated.entity.SysConfig">
        <id column="id" property="id"/>
        <result column="config_key" property="configKey"/>
        <result column="config_value" property="configValue" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="selectByConfigKey" resultMap="BaseResultMap">
        SELECT id, config_key, config_value, updated_at, created_at
        FROM sys_config
        WHERE config_key = #{configKey}
        LIMIT 1
    </select>
</mapper>
